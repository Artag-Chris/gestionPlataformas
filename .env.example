# ─────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASS=password
RABBITMQ_URL=amqp://admin:password@rabbitmq:5672

# ─────────────────────────────────────────
# Gateway
# ─────────────────────────────────────────
GATEWAY_PORT=3000
GATEWAY_DATABASE_URL=postgresql://user:password@host/gateway_db?sslmode=require

# JWT (comentado hasta activar auth)
# JWT_SECRET=your_super_secret_key_here
# JWT_EXPIRATION=3600

# ─────────────────────────────────────────
# WhatsApp Service
# ─────────────────────────────────────────
WHATSAPP_PORT=3001
WHATSAPP_DATABASE_URL=postgresql://user:password@host/whatsapp_db?sslmode=require

# Meta Cloud API
WHATSAPP_API_TOKEN=your_meta_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_API_VERSION=v19.0
