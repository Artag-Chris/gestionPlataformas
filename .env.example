# ─────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASS=password
RABBITMQ_URL=amqp://admin:password@rabbitmq:5672

# ─────────────────────────────────────────
# Gateway
# ─────────────────────────────────────────
GATEWAY_PORT=3000
GATEWAY_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# JWT (comentado hasta activar auth)
# JWT_SECRET=your_super_secret_key_here
# JWT_EXPIRATION=3600

# ─────────────────────────────────────────
# WhatsApp Service
# ─────────────────────────────────────────
WHATSAPP_PORT=3001
WHATSAPP_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Meta Cloud API
WHATSAPP_API_TOKEN=your_meta_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_API_VERSION=v19.0

# WhatsApp Template (fallback for 24h window)
WHATSAPP_TEMPLATE_NAME=presentacion_de_ia
WHATSAPP_TEMPLATE_LANGUAGE=en

# ─────────────────────────────────────────
# Slack Service
# ─────────────────────────────────────────
SLACK_PORT=3002
SLACK_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# ─────────────────────────────────────────
# Notion Service
# ─────────────────────────────────────────
NOTION_PORT=3003
NOTION_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
NOTION_INTEGRATION_TOKEN=secret_your_notion_integration_token_here

# ─────────────────────────────────────────
# Instagram Service
# ─────────────────────────────────────────
INSTAGRAM_PORT=3004
INSTAGRAM_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_PAGE_ID=your_instagram_page_id_here
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=my_instagram_webhook_verify_token_change_this
INSTAGRAM_API_VERSION=v19.0

# ─────────────────────────────────────────
# TikTok Service
# ─────────────────────────────────────────
TIKTOK_PORT=3005
TIKTOK_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
TIKTOK_APP_ID=your_tiktok_app_id_here
TIKTOK_APP_SECRET=your_tiktok_app_secret_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# ─────────────────────────────────────────
# Facebook Service
# ─────────────────────────────────────────
FACEBOOK_PORT=3006
FACEBOOK_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
FACEBOOK_WEBHOOK_VERIFY_TOKEN=my_facebook_webhook_verify_token_change_this
FACEBOOK_API_VERSION=v19.0

# ─────────────────────────────────────────
# Email Service
# ─────────────────────────────────────────
EMAIL_PORT=3007
EMAIL_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@tudominio.com
